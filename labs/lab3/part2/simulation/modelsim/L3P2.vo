defparam \Clk~I .output_sync_reset = "none";
// synopsys translate_on

// Location: LCCOMB_X49_Y5_N16
cycloneii_lcell_comb \Qa~0 (
// Equation(s):
// \Qa~0_combout  = (\Clk~combout  & (!\D~combout )) # (!\Clk~combout  & ((\Qa~0_combout )))

